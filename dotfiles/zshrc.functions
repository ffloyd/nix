# Terminal color codes
NOCOLOR="\033[0m";
RED="\033[0;31m";
GREEN="\033[0;32m";
ORANGE="\033[0;33m";
BLUE="\033[0;34m";
PURPLE="\033[0;35m";
CYAN="\033[0;36m";
LIGHTGRAY="\033[0;37m";
DARKGRAY="\033[1;30m";
LIGHTRED="\033[1;31m";
LIGHTGREEN="\033[1;32m";
YELLOW="\033[1;33m";
LIGHTBLUE="\033[1;34m";
LIGHTPURPLE="\033[1;35m";
LIGHTCYAN="\033[1;36m";
WHITE="\033[1;37m";

# I use it for long-running tasks
doit() {
    local cmd="$1"
    shift  # Shift the arguments to the left, so $@ now contains the remaining arguments
    eval "$cmd $@ && say 'Done' || say 'Oh fuck, it is failed'"
}

_how() {
  if [[ "$OSTYPE" == "darwin"* ]]; then
    local model="anthropic/claude-haiku-4-5"
  else
    local model="opencode-go/deepseek-v4-flash"
  fi

  opencode -m $model --agent plan run "Answer concisely and briefly (several sentences): how $*" 2> /dev/null | bat -p -l md
}

# allows to use ?, * in arguments as part of strings (without glob expansion)
alias how='noglob _how'

notify-ai-finished-task() {
  if [[ "$OSTYPE" == "darwin"* ]]; then
    osascript -e 'display notification "The current task is done!" with title "AI Assistant"'
  else
    notify-send -e -a "AI Assistant" "Current Task is Done!"
  fi
}

pdf-compress-very-much() {
  local input="$1"
  local output="$2"

  # /screen  - 72 dpi
  # /ebook   - 150 dpi <--
  # /printer - 300 dpi
  nix-shell -p ghostscript --run "gs -sDEVICE=pdfwrite -dCompatibilityLevel=1.4 -dPDFSETTINGS=/ebook -dNOPAUSE -dQUIET -dBATCH -sOutputFile=output.pdf Mietvertrag_Mozartstr.pdf"
}
