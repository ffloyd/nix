{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "opencode",
    "opencode-go"
  ],
  "model": "opencode-go/deepseek-v4-pro",
  "plugin": [
    "@mohak34/opencode-notifier@latest"
  ],
  "mcp": {
    "ctx7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "kagi": {
      "enabled": true,
      "type": "local",
      "command": [
        "uvx",
        "kagimcp"
      ]
    }
  }
}
